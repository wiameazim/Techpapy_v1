    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prisma": "^6.3.1",
    "prom-client": "^15.1.3",
    "sanitize-html": "^2.14.0",
    "socket.io": "^4.8.3",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
